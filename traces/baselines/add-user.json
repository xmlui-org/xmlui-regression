        "ariaRole": "button",
        "ariaName": "Save",
        "testId": "userDialog"
      },
      "validationErrors": [
        {
          "form": "Form",
          "errorCount": 1,
          "errorFields": [
            "email"
          ]
        }
      ]
    },
    {
      "action": "click",
      "target": {
        "component": "ModalDialog",
        "label": "Add User",
        "componentId": "userDialog",
        "targetTag": "INPUT",
        "ariaRole": "textbox",
        "ariaName": "Email",
